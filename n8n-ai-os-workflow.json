    {
      "parameters": {
        "name": "query_travel_packages",
        "description": "Use this tool to search active packages (Umrah, Hajj, or International) in the Packages sheet of Google Sheets. You can filter by category (Umrah, Hajj, International).",
        "jsCode": "const spreadsheetId = '1pfj3q2kutmk8AgqacsKzu3BA-RPwyq_XEGs82dpa4AY';\nconst category = args.category; // 'Umrah', 'Hajj', or 'International'\n\nconst res = await this.helpers.request({\n  method: 'GET',\n  url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Packages!A:H`,\n  useAuth: true\n});\nconst rows = res.values || [];\nconst headers = rows[0] || [];\nconst categoryIndex = headers.indexOf('Category');\nconst statusIndex = headers.indexOf('Status');\n\nconst packages = [];\nfor (let i = 1; i < rows.length; i++) {\n  const row = rows[i];\n  if (row[statusIndex] !== 'Active') continue;\n  if (category && row[categoryIndex] !== category) continue;\n  \n  const pkg = {};\n  headers.forEach((h, idx) => {\n    pkg[h] = row[idx] || null;\n  });\n  packages.push(pkg);\n}\nreturn { success: true, packages };"
      },
      "id": "packages-tool-id",
      "name": "Travel Packages Search Tool",
      "type": "@n8n/n8n-nodes-langchain.toolCustom",
      "typeVersion": 1,
      "position": [
        4600,
        2800
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "pHgrDDWKgv0xidHW",
          "name": "Google Sheets OAuth2 API"
        }
      }
    },
    {
      "parameters": {
        "name": "handle_complaint",
        "description": "Use this tool to log a support ticket in the SupportTickets sheet and pause the AI bot (BotActive = FALSE, ActiveAgent = Complaint) in the Leads sheet when a user has a complaint.",
        "jsCode": "const spreadsheetId = '1pfj3q2kutmk8AgqacsKzu3BA-RPwyq_XEGs82dpa4AY';\nconst phone = args.phone || $('Parse Incoming Details').item.json.phone;\nconst description = args.description;\nconst category = args.category || 'Other';\n\nconst resLeads = await this.helpers.request({\n  method: 'GET',\n  url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Leads!A:R`,\n  useAuth: true\n});\nconst rowsLeads = resLeads.values || [];\nconst headersLeads = rowsLeads[0] || [];\nconst phoneIndex = headersLeads.indexOf('SenderPhone');\nconst matchedIndex = rowsLeads.findIndex(r => r[phoneIndex] === phone);\n\nif (matchedIndex !== -1) {\n  const rowNum = matchedIndex + 1;\n  const botActiveIndex = headersLeads.indexOf('BotActive');\n  const activeAgentIndex = headersLeads.indexOf('ActiveAgent');\n  \n  await this.helpers.request({\n    method: 'PUT',\n    url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Leads!Q${rowNum}:R${rowNum}?valueInputOption=USER_ENTERED`,\n    body: { values: [[\"Complaint\", \"FALSE\"]] },\n    useAuth: true\n  });\n}\n\nconst ticketId = 'TCK-' + Math.floor(1000 + Math.random() * 9000);\nconst ticketRow = [ticketId, phone, category, description, 'Open', 'Unassigned', new Date().toISOString()];\n\nawait this.helpers.request({\n  method: 'POST',\n  url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/SupportTickets!A1:G1:append?valueInputOption=USER_ENTERED`,\n  body: { values: [ticketRow] },\n  useAuth: true\n});\n\nreturn { success: true, ticketId, message: \"Bot paused, support ticket created successfully.\" };"
      },
      "id": "complaint-tool-id",
      "name": "Complaint Manager Tool",
      "type": "@n8n/n8n-nodes-langchain.toolCustom",
