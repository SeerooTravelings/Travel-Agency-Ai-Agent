    {
      "parameters": {
        "name": "manage_crm_lead",
        "description": "Use this tool to get existing lead details or save/update lead details (Month, Persons, DepartureCity, Budget, ServiceType, Status, ActiveAgent, BotActive) in the Leads sheet.",
        "jsCode": "const spreadsheetId = '1pfj3q2kutmk8AgqacsKzu3BA-RPwyq_XEGs82dpa4AY';\nconst phone = args.phone || $('Parse Incoming Details').item.json.phone;\nconst action = args.action; // 'get' or 'update'\n\nif (action === 'get') {\n  const res = await this.helpers.request({\n    method: 'GET',\n    url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Leads!A:R`,\n    useAuth: true\n  });\n  const rows = res.values || [];\n  const headers = rows[0] || [];\n  const phoneIndex = headers.indexOf('SenderPhone');\n  const matchedRow = rows.find(r => r[phoneIndex] === phone);\n  if (!matchedRow) {\n    return { found: false, message: \"No existing lead found for this phone number.\" };\n  }\n  const lead = {};\n  headers.forEach((h, i) => {\n    lead[h] = matchedRow[i] || null;\n  });\n  return { found: true, lead };\n} else if (action === 'update') {\n  const data = args.data || {};\n  const res = await this.helpers.request({\n    method: 'GET',\n    url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Leads!A:R`,\n    useAuth: true\n  });\n  const rows = res.values || [];\n  const headers = rows[0] || [];\n  const phoneIndex = headers.indexOf('SenderPhone');\n  const matchedRowIndex = rows.findIndex(r => r[phoneIndex] === phone);\n\n  if (matchedRowIndex === -1) {\n    const newRow = headers.map(h => {\n      if (h === 'SenderPhone') return phone;\n      if (h === 'CreatedTime') return new Date().toISOString();\n      return data[h] || '';\n    });\n    await this.helpers.request({\n      method: 'POST',\n      url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Leads!A1:append?valueInputOption=USER_ENTERED`,\n      body: { values: [newRow] },\n      useAuth: true\n    });\n    return { success: true, action: 'created', message: 'New lead row added successfully.' };\n  } else {\n    const rowNum = matchedRowIndex + 1;\n    const existingRow = rows[matchedRowIndex];\n    const updatedRow = headers.map((h, i) => {\n      if (h === 'SenderPhone') return phone;\n      if (data[h] !== undefined) return data[h];\n      return existingRow[i] || '';\n    });\n    await this.helpers.request({\n      method: 'PUT',\n      url: `https://sheets.googleapis.com/v4/spreadsheets/${spreadsheetId}/values/Leads!A${rowNum}:R${rowNum}?valueInputOption=USER_ENTERED`,\n      body: { values: [updatedRow] },\n      useAuth: true\n    });\n    return { success: true, action: 'updated', message: `Lead row ${rowNum} updated successfully.` };\n  }\n}"
      },
      "id": "crm-tool-id",
      "name": "CRM Lead Manager Tool",
      "type": "@n8n/n8n-nodes-langchain.toolCustom",
      "typeVersion": 1,
      "position": [
        4400,
